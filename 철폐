<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>세븐나이츠 리버스 길드전 예약 시스템 v12</title>
    <style>
        body { background-color: #0f172a; color: #f8fafc; font-family: 'Malgun Gothic', sans-serif; margin: 0; padding: 20px; }
        .container { max-width: 1400px; margin: 0 auto; display: flex; gap: 20px; flex-direction: column; }
        @media (min-width: 1024px) { .container { flex-direction: row; } }
        
        /* 왼쪽 길드원 관리 및 종합 전적 현황판 */
        .guild-sidebar { flex: 1; max-width: 100%; background-color: #1e293b; padding: 20px; border-radius: 12px; border: 1px solid #334155; height: fit-content; }
        @media (min-width: 1024px) { .guild-sidebar { max-width: 440px; position: sticky; top: 20px; } }
        
        /* 관리자 인증 박스 */
        .admin-lock-box { background-color: #0f172a; padding: 12px; border-radius: 8px; border: 1px solid #475569; margin-bottom: 15px; text-align: center; }
        .lock-status { font-size: 13px; font-weight: bold; margin-bottom: 8px; display: block; }
        .lock-status.locked { color: #f43f5e; }
        .lock-status.unlocked { color: #22c55e; }
        .input-pw { width: 80%; text-align: center; padding: 4px; font-size: 12px; margin-bottom: 4px; }
        
        /* 현황판 리스트 스타일 고도화 */
        .member-status-list { display: flex; flex-direction: column; gap: 6px; margin-top: 10px; max-height: 550px; overflow-y: auto; padding-right: 4px; }
        .member-row { display: flex; align-items: center; justify-content: space-between; background-color: #0f172a; padding: 8px 10px; border-radius: 6px; border: 1px solid #334155; gap: 4px; }
        .member-row.me { border-color: #0284c7; background-color: #0c1e36; }
        .member-row.exhausted { opacity: 0.7; background-color: #1c1116; }
        .input-name { width: 80px; background: transparent; border: none; color: white; font-size: 13px; font-weight: bold; }
        .input-name:disabled { border-bottom: none; }
        .input-name:not(:disabled) { border-bottom: 1px dashed #475569; text-align: center; }
        
        /* 비밀번호 입력창 (관리자 전용) */
        .input-user-pw { width: 45px; text-align: center; background-color: #1e293b; border: 1px solid #64748b; color: #a78bfa; border-radius: 4px; padding: 1px; font-size: 11px; }

        /* 스탯 박스 영역 */
        .stat-group { display: flex; align-items: center; gap: 6px; font-size: 11px; color: #cbd5e1; }
        .stat-item { display: flex; align-items: center; gap: 2px; }
        .input-stat { width: 26px; text-align: center; background-color: #1e293b; border: 1px solid #475569; border-radius: 4px; padding: 1px; font-size: 11px; font-weight: bold; }
        .input-stat.t-count { color: #facc15; }
        .input-stat.s-count { color: #38bdf8; }
        .input-stat.f-count { color: #fb923c; }

        .status-badge { font-size: 11px; padding: 2px 6px; border-radius: 4px; font-weight: bold; text-align: center; min-width: 42px; }
        .status-badge.avail { background-color: #1e3a8a; color: #38bdf8; }
        .status-badge.empty { background-color: #4c0519; color: #f43f5e; }
        
        /* 오른쪽 메인 콘텐츠 */
        .main-content { flex: 3; }
        
        header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #334155; padding-bottom: 20px; margin-bottom: 25px; }
        h1 { color: #facc15; margin: 0; font-size: 24px; }
        .nickname-box { display: flex; align-items: center; gap: 10px; background: #1e293b; padding: 8px 16px; border-radius: 8px; border: 1px solid #334155; }
        .user-badge { background-color: #0284c7; padding: 4px 8px; border-radius: 4px; font-weight: bold; font-size: 13px; }
        .logout-btn { background: #475569; border: none; color: white; padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 11px; }
        .logout-btn:hover { background: #f43f5e; }
        
        input, select { background-color: #0f172a; border: 1px solid #475569; color: white; padding: 6px 10px; border-radius: 6px; outline: none; font-size: 14px; }
        input:focus, select:focus { border-color: #facc15; }
        
        .tab-section { margin-bottom: 25px; }
        .tab-group { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 15px; }
        .tab-label { font-size: 14px; font-weight: bold; color: #94a3b8; width: 100%; margin-bottom: 5px; }
        .tab-btn { background-color: #1e293b; border: 1px solid #334155; color: #cbd5e1; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .tab-btn.active.outer { background-color: #0284c7; color: white; border-color: #38bdf8; }
        .tab-btn.active.inner { background-color: #7c3aed; color: white; border-color: #a78bfa; }
        .tab-btn.active.main { background-color: #dc2626; color: white; border-color: #f87171; }

        .current-title { font-size: 20px; font-weight: bold; margin-bottom: 20px; padding-left: 10px; border-left: 5px solid #facc15; }
        .grid { display: grid; grid-template-cols: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px; }
        
        .card { background-color: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 16px; box-shadow: 0 4px 6px rgba(0,0,0,0.2); display: flex; flex-direction: column; justify-content: space-between; }
        .card.reserved { border: 1px solid #eab308; background-color: #1c1917; }
        .card.fail { border: 1px solid #f97316; background-color: #2a1b10; }
        .card.done { border: 1px solid #dc2626; background-color: #180505; opacity: 0.7; }
        
        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .castle-name { font-weight: bold; font-size: 16px; color: #f1f5f9; }
        
        .badge { font-size: 11px; padding: 2px 6px; border-radius: 4px; font-weight: bold; }
        .badge.ready { background-color: #22c55e; color: #000; }
        .badge.ing { background-color: #eab308; color: #000; }
        .badge.fail { background-color: #f97316; color: #000; }
        .badge.done { background-color: #dc2626; color: #fff; }
        
        .info-row { background-color: #0f172a; padding: 8px; border-radius: 6px; margin-bottom: 6px; font-size: 13px; display: flex; align-items: center; justify-content: space-between; }
        .info-label { color: #94a3b8; font-size: 12px; }
        .input-defender { width: 120px; text-align: right; background: transparent; border: none; border-bottom: 1px dashed #475569; color: white; }
        .input-defender:disabled, .input-failcount:disabled { color: #64748b; border-color: transparent; cursor: not-allowed; }
        .input-failcount { width: 50px; text-align: center; background-color: #1e293b; border: 1px solid #475569; color: #f97316; font-weight: bold; border-radius: 4px; padding: 2px; }
        
        .name-text { font-weight: bold; }

        .btn { width: 100%; background-color: #2563eb; color: white; border: none; padding: 8px; border-radius: 6px; font-weight: bold; cursor: pointer; margin-top: 10px; }
        .btn:hover { background-color: #1d4ed8; }
        .btn-group-3 { display: flex; gap: 6px; margin-top: 10px; }
        .btn-3 { flex: 1; border: none; padding: 8px 4px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 12px; color: white; }
        .btn-success { background-color: #dc2626; }
        .btn-failure { background-color: #ea580c; }
        .btn-cancel { background-color: #475569; }
    </style>
</head>
<body>

<div class="container">
    <!-- 왼쪽: 길드원 관리 및 종합 전적 현황판 (비밀번호 기능 추가) -->
    <div class="guild-sidebar">
        <h3 style="margin: 0; color: #facc15; font-size: 16px; border-bottom: 1px solid #334155; padding-bottom: 10px;">👥 길드원 보안 현황판</h3>
        
        <div class="admin-lock-box">
            <span id="lock-icon" class="lock-status locked">🔒 명단 잠김 (수정 불가)</span>
            <input type="password" id="admin-password" class="input-pw" placeholder="관리자 비번 입력" oninput="checkPassword(this.value)">
        </div>

        <!-- 30명 현황판 영역 -->
        <div class="member-status-list" id="member-status-container"></div>
    </div>

    <!-- 오른쪽: 메인 콘텐츠 -->
    <div class="main-content">
        <header>
            <div>
                <h1>⚔️ 세븐나이츠 리버스 길드전</h1>
                <div style="color: #94a3b8; font-size: 12px; margin-top: 4px;">개인 핀번호(비밀번호) 보안 기능 탑재 v12</div>
            </div>
            <div class="nickname-box">
                <span style="font-size: 13px; color:#94a3b8;">접속자:</span>
                <span class="user-badge" id="current-user-display">로그인 필요</span>
                <button class="logout-btn" onclick="logout()">계정 전환</button>
            </div>
        </header>

        <!-- 거점 선택 탭 -->
        <div class="tab-section">
            <div class="tab-label">🛡️ 외성 구역 (각 10개 덱)</div>
            <div class="tab-group">
                <button class="tab-btn active outer" onclick="switchCastle('외성 1번')">외성 1번</button>
                <button class="tab-btn outer" onclick="switchCastle('외성 2번')">외성 2번</button>
                <button class="tab-btn outer" onclick="switchCastle('외성 3번')">외성 3번</button>
                <button class="tab-btn outer" onclick="switchCastle('외성 4번')">외성 4번</button>
                <button class="tab-btn outer" onclick="switchCastle('외성 5번')">외성 5번</button>
            </div>
            <div class="tab-label">🏰 내성 구역 (각 15개 덱)</div>
            <div class="tab-group">
                <button class="tab-btn inner" onclick="switchCastle('내성 1번')">내성 1번</button>
                <button class="tab-btn inner" onclick="switchCastle('내성 2번')">내성 2번</button>
                <button class="tab-btn inner" onclick="switchCastle('내성 3번')">내성 3번</button>
            </div>
            <div class="tab-label">👑 본성 구역 (20개 덱)</div>
            <div class="tab-group">
                <button class="tab-btn main" onclick="switchCastle('본성')">본성 (주성)</button>
            </div>
        </div>

        <div class="current-title" id="current-castle-title">외성 1번 방어덱 현황</div>
        <div class="grid" id="deck-grid"></div>
    </div>
</div>

<script>
    const REAL_ADMIN_PASSWORD = "1234"; 
    let isAdminMode = false; 

    // 데이터 구조에 비밀번호(password) 추가. 초기값은 "0000"
    let guildMembers = JSON.parse(localStorage.getItem('skr_guild_members_v4')) || 
                       Array(30).fill(null).map(() => ({ name: "", password: "0000", tickets: 5, success: 0, fail: 0 }));
    
    let DecksData = JSON.parse(localStorage.getItem('skr_decks_data')) || [];
    let currentUser = localStorage.getItem('skr_current_user') || "";

    if (DecksData.length === 0) {
        let idCounter = 1;
        for (let c = 1; c <= 5; c++) { for (let d = 1; d <= 10; d++) { DecksData.push({ id: idCounter++, castleName: `외성 ${c}번`, deckNum: `${d}번 덱`, status: '대기중', defender: '', attacker: '', failCount: 0 }); } }
        for (let c = 1; c <= 3; c++) { for (let d = 1; d <= 15; d++) { DecksData.push({ id: idCounter++, castleName: `내성 ${c}번`, deckNum: `${d}번 덱`, status: '대기중', defender: '', attacker: '', failCount: 0 }); } }
        for (let d = 1; d <= 20; d++) { DecksData.push({ id: idCounter++, castleName: `본성`, deckNum: `${d}번 덱`, status: '대기중', defender: '', attacker: '', failCount: 0 }); }
        localStorage.setItem('skr_decks_data', JSON.stringify(DecksData));
    }

    // 왼쪽 종합 현황판 그리기
    function drawSidebar() {
        const container = document.getElementById('member-status-container');
        container.innerHTML = '';
        
        guildMembers.forEach((m, idx) => {
            const isMe = m.name === currentUser ? 'me' : '';
            const isExhausted = m.tickets <= 0 ? 'exhausted' : '';
            const isDisabled = !isAdminMode ? 'disabled' : '';
            
            let badgeHtml = `<span class="status-badge avail">참가중</span>`;
            if (m.name === "") {
                badgeHtml = `<span class="status-badge" style="color:#475569;">미등록</span>`;
            } else if (m.tickets <= 0) {
                badgeHtml = `<span class="status-badge empty">소진</span>`;
            }

            // 관리자 모드일 때만 비밀번호 칸이 보이고 편집 가능함
            let pwInputHtml = '';
            if (isAdminMode && m.name !== "") {
                pwInputHtml = `
                    <div class="stat-item">
                        <span style="color:#a78bfa;">비번:</span>
                        <input type="text" class="input-user-pw" value="${m.password || '0000'}" onchange="updateMemberPassword(${idx}, this.value)">
                    </div>`;
            }

            container.innerHTML += `
                <div class="member-row ${isMe} ${isExhausted}">
                    <input type="text" class="input-name" value="${m.name}" placeholder="길드원 ${idx+1}" ${isDisabled} onchange="updateMemberName(${idx}, this.value)">
                    
                    <div class="stat-group">
                        ${pwInputHtml}
                        <div class="stat-item">
                            <span style="color:#94a3b8;">남은:</span>
                            <input type="number" class="input-stat t-count" value="${m.tickets}" min="0" max="5" ${isDisabled} onchange="updateMemberStat(${idx}, 'tickets', this.value)">
                        </div>
                        <div class="stat-item">
                            <span style="color:#38bdf8;">성공:</span>
                            <input type="number" class="input-stat s-count" value="${m.success || 0}" min="0" ${isDisabled} onchange="updateMemberStat(${idx}, 'success', this.value)">
                        </div>
                        <div class="stat-item">
                            <span style="color:#fb923c;">실패:</span>
                            <input type="number" class="input-stat f-count" value="${m.fail || 0}" min="0" ${isDisabled} onchange="updateMemberStat(${idx}, 'fail', this.value)">
                        </div>
                    </div>
                    
                    ${badgeHtml}
                </div>
            `;
        });
    }

    function updateMemberName(index, value) {
        guildMembers[index].name = value.trim();
        // 이름을 새로 등록하면 해당 슬롯 비번은 0000으로 자동 리셋
        if (guildMembers[index].name !== "" && !guildMembers[index].password) {
            guildMembers[index].password = "0000";
        }
        saveMembers();
        drawSidebar();
    }

    function updateMemberPassword(index, value) {
        guildMembers[index].password = value.trim() || "0000";
        saveMembers();
        drawSidebar();
    }

    function updateMemberStat(index, field, value) {
        guildMembers[index][field] = Math.max(0, parseInt(value) || 0);
        saveMembers();
        drawSidebar();
        drawDecks();
    }

    function saveMembers() {
        localStorage.setItem('skr_guild_members_v4', JSON.stringify(guildMembers));
    }

    function getGuildMemberObj(name) {
        return guildMembers.find(m => m.name !== "" && m.name === name);
    }

    // ★ [보안 고도화] 닉네임 + 비밀번호 2차 검증 인증 시스템
    function authGateway() {
        const emptyCheck = guildMembers.filter(m => m.name !== "").length;
        if (emptyCheck === 0) {
            currentUser = "초기관리자";
            document.getElementById('current-user-display').innerText = currentUser;
            alert("⚠️ 등록된 길드원이 없습니다! 관리자 비번을 입력해 명단을 먼저 세팅하세요.");
            return;
        }

        while (true) {
            if (currentUser && (currentUser === "초기관리자" || getGuildMemberObj(currentUser))) {
                document.getElementById('current-user-display').innerText = currentUser;
                break; 
            }
            
            let nameInput = prompt("🛡️ [로그인] 닉네임을 입력하세요:");
            if (nameInput === null) {
                authCancelAction();
                return;
            }
            
            nameInput = nameInput.trim();
            const userObj = getGuildMemberObj(nameInput);

            if (userObj) {
                // 비밀번호 확인 검증창
                let pwInput = prompt(`🔑 [${nameInput}]님의 4자리 비밀번호(핀번호)를 입력하세요:\n(초기 비밀번호는 0000 입니다)`);
                if (pwInput === null) {
                    authCancelAction();
                    return;
                }

                if (userObj.password === pwInput.trim()) {
                    currentUser = nameInput;
                    localStorage.setItem('skr_current_user', currentUser);
                    document.getElementById('current-user-display').innerText = currentUser;

                    // 만약 초기 비번 0000이면 강제 변경 유도
                    if (pwInput.trim() === "0000") {
                        let newPw = prompt("⚠️ 보안을 위해 새로운 비밀번호(4자리 권장)를 입력해 주세요:");
                        if (newPw && newPw.trim() !== "" && newPw.trim() !== "0000") {
                            userObj.password = newPw.trim();
                            saveMembers();
                            alert("✅ 비밀번호가 변경되었습니다! 반드시 기억해 주세요.");
                        } else {
                            alert("⚠️ 비밀번호를 바꾸지 않았습니다. 다음 로그인 때 다시 요청됩니다.");
                        }
                    }

                    alert(`🔓 인증 성공! [${currentUser}]님 반갑습니다.`);
                    break;
                } else {
                    alert("❌ 비밀번호가 올바르지 않습니다. 도용 시도가 의심됩니다.");
                }
            } else {
                alert(`❌ [${nameInput}]은 명단에 없는 이름입니다.`);
            }
        }
    }

    function authCancelAction() {
        alert("인증에 실패했습니다. 접근이 차단됩니다.");
        document.body.innerHTML = "<h2 style='text-align:center; margin-top:100px; color:#f43f5e;'>❌ 길드원 전용 페이지입니다. 올바른 계정 정보로 로그인해 주세요.</h2><p style='text-align:center;'><button onclick='location.reload()' style='padding:10px; font-weight:bold; cursor:pointer;'>다시 로그인하기</button></p>";
    }

    function logout() {
        localStorage.removeItem('skr_current_user');
        currentUser = "";
        location.reload();
    }

    function checkPassword(inputPw) {
        const lockIcon = document.getElementById('lock-icon');
        if (inputPw === REAL_ADMIN_PASSWORD) {
            lockIcon.innerText = "🔓 인증 완료 (명단/기회/비번 편집 가능)";
            lockIcon.className = "lock-status unlocked";
            isAdminMode = true;
        } else {
            lockIcon.innerText = "🔒 명단 잠김 (수정 불가)";
            lockIcon.className = "lock-status locked";
            isAdminMode = false;
        }
        drawSidebar();
    }

    let currentCastle = '외성 1번';

    function hasPermission(deck) {
        if (deck.attacker === "" || deck.attacker === currentUser || isAdminMode) {
            return true;
        }
        return false;
    }

    function drawDecks() {
        const grid = document.getElementById('deck-grid');
        grid.innerHTML = '';
        document.getElementById('current-castle-title').innerText = `${currentCastle} 방어덱 현황`;

        const filtered = DecksData.filter(d => d.castleName === currentCastle);

        filtered.forEach(d => {
            let cardClass = 'card';
            let badgeClass = 'badge ready';
            let actionHtml = '';
            let attackerContent = `<span class="name-text" style="color:#64748b;">없음</span>`;
            
            const isInputDisabled = !hasPermission(d) ? 'disabled' : '';

            let defenderContent = `<input type="text" class="input-defender" placeholder="클릭 후 입력" value="${d.defender}" ${isInputDisabled} onchange="updateDefender(${d.id}, this.value)">`;
            if (d.status === '완파') {
                defenderContent = `<span class="name-text" style="color:#f1f5f9;">${d.defender || '미등록'}</span>`;
            }

            if (d.status === '대기중') {
                actionHtml = `<button class="btn" onclick="book(${d.id})">공격 예약</button>`;
            } else if (d.status === '예약됨') {
                badgeClass = 'badge ing';
                cardClass = 'card reserved';
                attackerContent = `<span class="name-text" style="color:#facc15;">⚡ ${d.attacker} (선점)</span>`;
                actionHtml = `
                    <div class="btn-group-3">
                        <button class="btn-3 btn-success" onclick="useTicketAndChangeState(${d.id}, '완파')">완파</button>
                        <button class="btn-3 btn-failure" onclick="useTicketAndChangeState(${d.id}, '공격실패')">실패</button>
                        <button class="btn-3 btn-cancel" onclick="changeState(${d.id}, '대기중')">취소</button>
                    </div>`;
            } else if (d.status === '공격실패') {
                badgeClass = 'badge fail';
                cardClass = 'card fail';
                attackerContent = `<span class="name-text" style="color:#f97316;">❌ 최근공격: ${d.attacker}</span>`;
                actionHtml = `<button class="btn" style="background-color:#ea580c;" onclick="book(${d.id})">재도전 예약</button>`;
            } else if (d.status === '완파') {
                badgeClass = 'badge done';
                cardClass = 'card done';
                attackerContent = `<span class="name-text" style="color:#f43f5e;">💥 완파자: ${d.attacker}</span>`;
                actionHtml = `<button class="btn" style="background:#334155;" onclick="resetDeck(${d.id})">덱 초기화</button>`;
            }

            const html = `
                <div class="${cardClass}">
                    <div>
                        <div class="card-header">
                            <span class="castle-name">${d.deckNum}</span>
                            <span class="${badgeClass}">${d.status}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">🛡️ 방어자</span>
                            ${defenderContent}
                        </div>
                        <div class="info-row">
                            <span class="info-label">⚔️ 공격자</span>
                            ${attackerContent}
                        </div>
                        <div class="info-row">
                            <span class="info-label">⚠️ 누적 실패 횟수</span>
                            <input type="number" class="input-failcount" value="${d.failCount}" min="0" ${isInputDisabled} onchange="updateFailCount(${d.id}, this.value)">
                        </div>
                    </div>
                    ${actionHtml}
                </div>`;
            grid.innerHTML += html;
        });
    }

    function saveToStorage() { localStorage.setItem('skr_decks_data', JSON.stringify(DecksData)); }

    function updateDefender(id, value) { 
        const deck = DecksData.find(d => d.id === id);
        if (!hasPermission(deck)) { alert(`❌ 수정 불가: 타인이 사용 중인 성물 설정입니다.`); drawDecks(); return; }
        deck.defender = value; 
        saveToStorage();
    }
    
    function updateFailCount(id, value) {
        const deck = DecksData.find(d => d.id === id);
        if (!hasPermission(deck)) { alert(`❌ 수정 불가: 타인이 사용 중인 성물 설정입니다.`); drawDecks(); return; }
        deck.failCount = parseInt(value) || 0;
        saveToStorage();
        drawDecks();
    }

    function book(id) {
        if (!currentUser || currentUser === "초기관리자") { alert("공격 예약 권한이 없습니다."); return; }
        
        const userObj = getGuildMemberObj(currentUser);
        if (userObj && userObj.tickets <= 0) {
            alert("❌ 예약 불가: 남은 도전 기회가 0회입니다!");
            return;
        }

        const deck = DecksData.find(d => d.id === id);
        if (deck.status === '예약됨') { alert(`⚠️ 이미 예약된 방어덱입니다!`); return; }
        
        deck.status = '예약됨';
        deck.attacker = currentUser;
        saveToStorage();
        drawDecks();
    }

    function useTicketAndChangeState(id, nextStatus) {
        const deck = DecksData.find(d => d.id === id);
        if (!hasPermission(deck)) { alert(`❌ 권한 없음: 타인의 공략 상황입니다.`); return; }

        const targetUser = deck.attacker;
        const userObj = guildMembers.find(m => m.name === targetUser);
        
        if (userObj) {
            if (userObj.tickets <= 0 && !isAdminMode) {
                alert("기회가 없는 유저입니다. 결과 처리가 거부되었습니다.");
                return;
            }
            userObj.tickets = Math.max(0, userObj.tickets - 1);
            
            if (nextStatus === '완파') {
                userObj.success = (userObj.success || 0) + 1;
            } else if (nextStatus === '공격실패') {
                userObj.fail = (userObj.fail || 0) + 1;
            }
            saveMembers();
        }

        deck.status = nextStatus;
        if (nextStatus === '공격실패') {
            deck.failCount += 1;
        }
        
        saveToStorage();
        drawSidebar(); 
        drawDecks();
    }

    function changeState(id, status) {
        const deck = DecksData.find(d => d.id === id);
        if (!hasPermission(deck)) { alert(`❌ 권한 없음: 타인의 공략 상황입니다.`); return; }
        deck.status = status;
        if (status === '대기중') deck.attacker = '';
        saveToStorage();
        drawDecks();
    }

    function resetDeck(id) {
        const deck = DecksData.find(d => d.id === id);
        deck.status = '대기중';
        deck.attacker = '';
        deck.failCount = 0;
        saveToStorage();
        drawDecks();
    }

    function switchCastle(castleName) {
        currentCastle = castleName;
        const buttons = document.querySelectorAll('.tab-btn');
        buttons.forEach(btn => {
            btn.classList.remove('active');
            if(btn.innerText === castleName || (castleName === '본성' && btn.innerText.includes('본성'))) { btn.classList.add('active'); }
        });
        drawDecks();
    }

    authGateway();
    drawSidebar();
    drawDecks();
</script>
</body>
</html>
